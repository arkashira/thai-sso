import os
from typing import Optional
from fastapi import FastAPI, Request, Response, Cookie, HTTPException
from fastapi.responses import HTMLResponse, RedirectResponse
from fastapi.templating import Jinja2Templates
from fastapi.staticfiles import StaticFiles
from fastapi.middleware.sessions import SessionMiddleware

app = FastAPI(title="Thai SSO - PDPA Compliant")

# Configuration
SECRET_KEY = "axentx-sso-secret-key-change-in-production"
SESSION_COOKIE_NAME = "thai_sso_session"

# Setup Templates
templates = Jinja2Templates(directory="templates")

# Middleware to handle sessions
app.add_middleware(
    SessionMiddleware,
    secret_key=SECRET_KEY,
    session_cookie=SESSION_COOKIE_NAME,
    max_age=3600 * 24 * 7, # 1 week
)

# In-memory store for "Users" (In production, use a DB)
users_db = {
    "admin": {"password": "password123", "name": "Admin User"},
    "user1": {"password": "password123", "name": "Employee One"}
}

# In-memory store for PDPA Consent Logs (Compliance tracking)
consent_logs = []

@app.get("/", response_class=HTMLResponse)
async def read_root(request: Request):
    """Redirects to login page."""
    return RedirectResponse(url="/login")

@app.get("/login", response_class=HTMLResponse)
async def login_page(request: Request):
    """Renders the login form."""
    return templates.TemplateResponse("login.html", {"request": request})

@app.post("/login")
async def login(request: Request, username: str, password: str, pdpa_consent: bool = False):
    """
    Authenticates user and captures PDPA consent.
    """
    if not pdpa_consent:
        raise HTTPException(status_code=400, detail="PDPA Consent is required to proceed.")

    user = users_db.get(username)
    if not user or user["password"] != password:
        raise HTTPException(status_code=401, detail="Invalid credentials")

    # Log consent for compliance
    consent_logs.append({
        "username": username,
        "timestamp": request.state.client_host,
        "consent_given": True
    })

    # Set session
    request.session["user"] = user["name"]
    request.session["username"] = username
    
    return RedirectResponse(url="/dashboard")

@app.get("/dashboard", response_class=HTMLResponse)
async def dashboard(request: Request):
    """Protected route accessible only after login."""
    if "user" not in request.session:
        return RedirectResponse(url="/login")
    
    user_name = request.session.get("user")
    return templates.TemplateResponse("dashboard.html", {"request": request, "user": user_name})

@app.get("/logout")
async def logout(request: Request):
    """Clears session."""
    request.session.clear()
    return RedirectResponse(url="/login")

